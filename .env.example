# PostgreSQL connection
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance_manager
POSTGRES_PORT=5432

# Server DATABASE_URL (used by Prisma)
DATABASE_URL="postgresql://finance:finance@localhost:5432/finance_manager"

# Server
PORT=3000
NODE_ENV=development

# Client (Vite prefix required for browser exposure)
VITE_API_BASE_URL=http://localhost:3000

# Admin credentials (used by seed script — never commit real values)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
SESSION_COOKIE_NAME=finance_session
SESSION_EXPIRY_DAYS=7
